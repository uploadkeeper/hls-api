874
00:53:21,865 --> 00:53:23,658
[tea pouring]

875
00:53:24,576 --> 00:53:25,577
[groans]

876
00:53:26,328 --> 00:53:27,329
[groans]

877
00:53:29,706 --> 00:53:30,707
[groans]

878
00:53:31,833 --> 00:53:32,834
[sighs]

879
00:53:32,918 --> 00:53:33,960
